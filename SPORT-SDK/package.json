{
  "name": "sports-jelly-sdk",
  "version": "0.1.0",
  "description": "Agent-first TypeScript SDK for multi-sport intelligence and prediction-market decision support — NBA, NFL, football, tennis, MLB, NHL and more.",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
