# WMarket Prediction SDK v2 — Environment Variables

# === Provider API Keys ===
LLAMAFI_API_KEY=your_llamafi_api_key_here
LLAMAFI_BASE_URL=https://api.llama.fi

# BNB Chain MCP endpoint
MCP_ENDPOINT=https://mcp.bnbchain.org
MCP_API_KEY=your_mcp_api_key_here

# Off-chain data providers
NEWS_API_KEY=your_news_api_key_here
SENTIMENT_API_KEY=your_sentiment_api_key_here
MACRO_API_KEY=your_macro_api_key_here

# === Chain RPC Endpoints ===
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-rpc.com

# === Redis (Optional Storage) ===
REDIS_URL=redis://localhost:6379

# === Telemetry (Optional) ===
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=wmarket-prediction-sdk

# === SDK Behaviour ===
SDK_LOG_LEVEL=info
SDK_CACHE_TTL_MS=300000
SDK_CONFIDENCE_THRESHOLD=0.6
SDK_RISK_TOLERANCE=medium

# === Webhook Secrets ===
WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret_here
