{
  "name": "@jellychain/sdk-core",
  "version": "1.0.0",
  "description": "Base SDK class, utilities, error handling, and testing framework for all Jelly Chain SDKs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
