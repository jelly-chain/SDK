    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@jellychain/shared-types": "*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "vitest": "^1.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jelly-chain/SDK.git",
    "directory": "packages/sdk-core"
  }
